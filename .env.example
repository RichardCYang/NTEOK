# [보안]
# 링크 미리보기 및 파비콘 프록시를 위한 HMAC 비밀키 (최소 32자 이상의 무작위 문자열 권장)
PROXY_SECRET=your_32_chars_random_secret_here
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# [데이터베이스]
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# 주의: 운영 환경에서는 반드시 강력한 비밀번호로 변경하세요.
DB_PASSWORD=your_secure_password_here
DB_NAME=nteok

# [레디스 (Redis)]
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# [관리자 계정]
# 주의: 운영 환경에서는 'admin' 이외의 사용자 이름과 강력한 비밀번호를 권장합니다.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# [보안 핵심 설정]
# 운영 환경(NODE_ENV=production)에서는 아래 키들을 반드시 32바이트 이상의 무작위 문자열로 설정해야 합니다.
# 설정하지 않거나 기본값을 사용할 경우 서버가 시작되지 않습니다.
# 생성 예시 (Node.js): require('crypto').randomBytes(32).toString('hex')

# 세션 및 CSRF 서명용 키
CSRF_HMAC_KEY=change_me_to_a_long_random_secret

# 공유 페이지 댓글 CSRF 서명용 키
SHARED_COMMENT_CSRF_SECRET=change_me_to_a_long_random_secret

# TOTP(2차 인증) 설정값 암호화용 키 (AES-256-GCM)
TOTP_SECRET_ENC_KEY=change_me_to_a_long_random_secret

# 백업 파일 무결성 서명용 키
BACKUP_SIGNING_KEY=change_me_to_a_long_random_secret

# [쿠키 및 네트워크 보안]
# HTTPS 강제 여부 (운영 환경 권장: true)
REQUIRE_HTTPS=false
# 개발 환경에서만 true로 설정하세요.
ALLOW_INSECURE_COOKIES=true
# HSTS 활성화 여부
ENABLE_HSTS=true

# [저장소 및 파일]
# 사용자당 최대 파일 저장 용량 (예: 1GB, 500MB)
MAX_PAPERCLIP_BYTES_PER_USER=1GB
# 휴지통 파일 보관 기간 (일)
PAPERCLIP_TRASH_RETENTION_DAYS=14

# [속도 제한 (Rate Limit)]
# IPv6 서브넷 마스킹 비트 (기본값: 56)
RATE_LIMIT_IPV6_SUBNET=56

# [레거시 호환성]
# 공유 댓글 API 에서 URL 경로에 포함된 토큰을 허용할지 여부 (기본값: false)
ALLOW_LEGACY_SHARE_TOKEN_IN_PATH=false
