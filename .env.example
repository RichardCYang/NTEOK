PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=admin
DB_NAME=nteok

REDIS_URL=redis://127.0.0.1:6379

ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

BCRYPT_SALT_ROUNDS=12

BASE_URL=http://localhost:3000

TRUST_PROXY=auto
TRUST_PROXY_CIDRS=127.0.0.1/32,::1/128

# TOTP 시도 제한 설정
TOTP_MAX_FAILS=8
TOTP_LOCK_MS=600000

# TOTP 비밀키 암호화용 32바이트(256비트) 키 (Base64 또는 Hex)
# 운영 환경 필수 설정 (미설정 시 재시작 후 기존 TOTP 사용 불가)
TOTP_SECRET_ENC_KEY=

DUCKDNS_DOMAIN=
DUCKDNS_TOKEN=
CERT_EMAIL=

# CSRF 토큰 서명용 HMAC 키 (서버 재시작 시에도 동일한 값 사용)
# 운영 환경 필수 설정 (미설정 시 런타임 랜덤 생성으로 인한 세션 끊김 발생)
CSRF_HMAC_KEY=

# 공유 페이지 댓글용 CSRF 비밀키
# 운영 환경 필수 설정 (SESSION_SECRET이 있으면 해당 값을 대체 사용 가능)
SHARED_COMMENT_CSRF_SECRET=